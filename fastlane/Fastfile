default_platform(:ios)

APP_IDENTIFIER = "com.henasys.app.cadencebeep"
SCHEME         = "CadenceBeep"
PROJECT        = "CadenceBeep.xcodeproj"
TEAM_ID        = "8CNAK8DRQG"

platform :ios do
  before_all do
    ENV["MATCH_PASSWORD"] ||= `security find-generic-password -a "CadenceBeep" -s "MATCH_PASSWORD" -w`.strip
  end

  desc "Setup App Store Connect API Key"
  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: `security find-generic-password -a "CadenceBeep" -s "ASC_API_KEY_ID" -w`.strip,
      issuer_id: `security find-generic-password -a "CadenceBeep" -s "ASC_API_ISSUER_ID" -w`.strip,
      key_filepath: `security find-generic-password -a "CadenceBeep" -s "ASC_API_KEY_PATH" -w`.strip,
      duration: 1200,
      in_house: false
    )
  end

  # ===================== Certificates =====================

  desc "Sync development certificates & profiles"
  lane :certs_dev do
    match(type: "development", api_key: asc_api_key, readonly: false)
  end

  desc "Sync App Store certificates & profiles"
  lane :certs_appstore do
    match(type: "appstore", api_key: asc_api_key, readonly: false)
  end

  desc "Read-only App Store cert sync (used before build)"
  private_lane :certs_appstore_ro do
    match(type: "appstore", api_key: asc_api_key, readonly: true)
  end

  # ===================== Build =====================

  desc "Bump build number to (latest TestFlight build + 1)"
  private_lane :bump_build do
    latest = latest_testflight_build_number(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0
    )
    increment_build_number(
      build_number: latest + 1,
      xcodeproj: PROJECT
    )
  end

  desc "Build release IPA (shared by beta & release)"
  private_lane :build_release do
    certs_appstore_ro
    bump_build
    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => "match AppStore #{APP_IDENTIFIER}"
        }
      },
      output_directory: "./build",
      output_name: "CadenceBeep.ipa",
      clean: true,
      include_symbols: true,
      include_bitcode: false
    )
  end

  # ===================== TestFlight =====================

  desc "Build & upload to TestFlight"
  lane :beta do |options|
    options ||= {}
    build_release
    upload_to_testflight(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      changelog: options[:changelog] || "Beta build via fastlane",
      distribute_external: false
    )
  end

  # ===================== Screenshots =====================

  desc "Capture screenshots via UI tests (snapshot)"
  lane :screenshots do
    capture_screenshots
  end

  desc "Upload screenshots only to App Store Connect"
  lane :upload_screenshots do
    upload_to_app_store(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Capture and upload screenshots"
  lane :refresh_screenshots do
    screenshots
    upload_screenshots
  end

  # ===================== Metadata =====================

  desc "Upload metadata only (no binary, no screenshots)"
  lane :upload_metadata do
    upload_to_app_store(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  # ===================== Production =====================

  desc "Build, upload binary + metadata + screenshots. Pass submit:true to also submit for review."
  lane :release do |options|
    options ||= {}
    build_release
    upload_to_app_store(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      submit_for_review: options[:submit] == true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      skip_metadata: options[:skip_metadata] == true,
      skip_screenshots: options[:skip_screenshots] == true,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )
  end
end
